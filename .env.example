# ============================================
# LeadForge - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# ── App Settings ──
APP_NAME=LeadForge
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production
API_BASE_URL=http://localhost:8000

# ── Supabase (Database + Auth) ──
# 1. Go to https://supabase.com → Create project
# 2. Go to Project Settings → API
# 3. Copy the URL and keys below
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# ── Redis ──
# Local: redis://localhost:6379/0
# Railway: Use the REDIS_URL from Railway dashboard
REDIS_URL=redis://localhost:6379/0

# ── Google Gemini (Primary LLM) ──
# 1. Go to https://aistudio.google.com/apikey
# 2. Create an API key
GOOGLE_API_KEY=your-google-api-key
GEMINI_MODEL=gemini-2.5-pro

# ── WhatsApp Business API ──
# 1. Go to https://developers.facebook.com
# 2. Create app → Add WhatsApp product
# 3. Go to WhatsApp → API Setup
# 4. Get temporary access token (or create System User for permanent token)
# 5. Note Phone Number ID and Business Account ID
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
WHATSAPP_VERIFY_TOKEN=your-custom-verify-token
WHATSAPP_API_VERSION=v21.0
# Rep's WhatsApp number for notifications (with country code, no +)
REP_WHATSAPP_NUMBER=919876543210

# ── Instagram (Meta Graph API) ──
# Uses same Facebook app as WhatsApp
# 1. Add Instagram product to your Facebook app
# 2. Connect Instagram Business account
INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-business-account-id

# ── Telegram Bot ──
# 1. Open Telegram, search @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# Rep's Telegram chat ID (send /start to your bot, then check updates)
REP_TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Twilio (Voice + SMS) ──
# 1. Go to https://www.twilio.com → Sign up
# 2. Get Account SID & Auth Token from Console
# 3. Buy a phone number
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ── Deepgram (Speech-to-Text) ──
# 1. Go to https://deepgram.com → Sign up
# 2. Create API key in Console
DEEPGRAM_API_KEY=your-deepgram-api-key

# ── ElevenLabs (Text-to-Speech) ──
# 1. Go to https://elevenlabs.io → Sign up
# 2. Get API key from Profile
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── SendGrid (Email) ──
# 1. Go to https://sendgrid.com → Sign up
# 2. Settings → API Keys → Create
# 3. Verify sender email
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com
SENDGRID_FROM_NAME=LeadForge

# ── Serper (Web Search) ──
# 1. Go to https://serper.dev → Sign up
# 2. Get API key from dashboard
SERPER_API_KEY=your-serper-api-key

# ── Pinecone (Vector DB) ──
# 1. Go to https://www.pinecone.io → Sign up
# 2. Create index: "leadforge-conversations", dimension=1536, metric=cosine
# 3. Get API key from console
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=leadforge-conversations
PINECONE_ENVIRONMENT=us-east-1

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_SOCKET_URL=http://localhost:8000
